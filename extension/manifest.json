{
  "manifest_version": 3,
  "name": "FormVault Ext",
  "version": "1.0.0",
  "description": "Secure form filler integrated with FormVault.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://docs.google.com/forms/*",
    "http://localhost:5000/*",
    "https://*.render.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
